From ac7167de3cc4544fe971fd0a99f8d5fea88ae4ad Mon Sep 17 00:00:00 2001
From: Mark Harfouche <mark@ramonaoptics.com>
Date: Mon, 11 May 2026 07:19:19 -0400
Subject: Link libwebpmux and libsharpyuv on conda-forge Windows

The native-Windows branch of setup.py already lists libwebpmux and
libsharpyuv; the conda-forge-Windows branch was missing them, so
imagecodecs/_webp.pyx fails to link on Windows in 2026.5.10 once
it started using WebPAnimEncoder*. Mirror the native-Windows list.
---
 setup.py | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/setup.py b/setup.py
index 1e261bd..d704655 100644
--- a/setup.py
+++ b/setup.py
@@ -637,7 +637,12 @@ def customize_build_condaforge(
         ]
         extensions['jpegls']['libraries'] = ['charls-2-x64']
         extensions['png']['libraries'] = ['libpng', 'z']
-        extensions['webp']['libraries'] = ['libwebp', 'libwebpdemux']
+        extensions['webp']['libraries'] = [
+            'libwebp',
+            'libwebpdemux',
+            'libwebpmux',
+            'libsharpyuv',
+        ]
         extensions['zopfli']['include_dirs'] = [
             os.path.join(os.environ['LIBRARY_INC'], 'zopfli')
         ]
